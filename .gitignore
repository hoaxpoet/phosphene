# Vendored third-party repos (tracked by pinned commit hash in docs).
# Beat This! reference impl for DSP.2 S8 layer-diff:
#   git clone --depth 1 https://github.com/CPJKU/beat_this vendor/beat_this_repo
#   cd vendor/beat_this_repo && git checkout 9d787b9797eaa325856a20897187734175467074
vendor/
tools/dragon_bloom_reference/oracle_recording.mov
__pycache__/

# quality_reel.mp4 (572 MB) lives as a GitHub Release asset (tag: assets-quality-reel),
# NOT in Git-LFS (CLEAN.5.8) — keeps it off the 10 GB/mo LFS bandwidth quota that
# public clones + CI were exhausting. Keep your local copy here to run
# QualityReelAnalyzer; re-download from the release on a fresh checkout.
docs/quality_reel.mp4

# Physarum/Filigree throwaway sketch renders (regenerate with RENDER_VISUAL=1)
tools/physarum_sketch/

# Mitosis (reaction–diffusion) throwaway sketch renders (regenerate with RENDER_VISUAL=1)
tools/mitosis_sketch/
# Mitosis gen-2 sketch renders (the shader Gen2Cell.metal IS committed; only frames are not)
tools/mitosis_gen2_sketch/frames/
tools/data/panns_reference/

# QG.3 coupling report per-frame CSVs (regenerable diagnostic artifacts)
coupling/

# Dev-only reference/diagnostic IMAGES — kept local, out of git (was LFS, purged
# to stop storage billing; no build target uses them). Text records (READMEs,
# diagnoses, contracts, source_*.txt/json) in these dirs STAY in git — only the
# raster images are ignored. Reinstate one with `git add -f` if ever needed.
docs/VISUAL_REFERENCES/**/*.jpg
docs/VISUAL_REFERENCES/**/*.jpeg
docs/VISUAL_REFERENCES/**/*.png
docs/VISUAL_REFERENCES/**/*.gif
docs/diagnostics/**/*.jpg
docs/diagnostics/**/*.jpeg
docs/diagnostics/**/*.png
docs/diagnostics/**/*.gif
