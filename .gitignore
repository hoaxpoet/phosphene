# CLEAN.5.4c: commit the two resolved files CI builds from (pin transitive SPM
# deps). Anchored '/' so PhospheneTools/ and worktree copies stay ignored.
!/PhospheneEngine/Package.resolved
!/PhospheneApp.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

